rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Client SDK access is completely locked down.
    // The FastAPI backend handles citizen uploads using the Admin SDK.
    // Public image viewing bypasses these rules because the backend generates signed download tokens (firebaseStorageDownloadTokens).
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
